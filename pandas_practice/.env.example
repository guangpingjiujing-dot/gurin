# データベース接続文字列（DB-API 2.0 対応のドライバで使用）
# このファイルを .env にコピーして、実際の値を設定してください
#
# Supabase の場合: Database > Connection string から取得
#   例: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# 他のPostgreSQL: postgresql://user:password@host:port/dbname
# SQLite の場合は sqlite3 モジュールに切り替え（接続文字列不要）

DATABASE_URL=postgresql://user:password@host:port/database
